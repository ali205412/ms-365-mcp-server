# Microsoft 365 OAuth Configuration
# Create an Azure AD app registration and get these values:

# Your Azure AD App Registration Client ID
MS365_MCP_CLIENT_ID=your-azure-ad-app-client-id-here

# Your Azure AD App Registration Client Secret (optional, for confidential clients)
MS365_MCP_CLIENT_SECRET=your-azure-ad-app-client-secret-here

# Tenant ID - use "common" for multi-tenant or your specific tenant ID
MS365_MCP_TENANT_ID=common

# Cloud environment: global (default) or china (21Vianet)
# MS365_MCP_CLOUD_TYPE=global

# Instructions for Global Cloud:
# 1. Go to https://portal.azure.com
# 2. Navigate to Azure Active Directory → App registrations → New registration
# 3. Set name: "MS365 MCP Server"
# 4. Add these redirect URIs (for MCP Inspector testing):
#    - http://localhost:6274/oauth/callback
#    - http://localhost:6274/oauth/callback/debug
#    - http://localhost:3000/callback (optional, for server callback)
# 5. Copy the Client ID from Overview page
# 6. Go to Certificates & secrets → New client secret → Copy the secret value
# 7. Replace the values above with your actual credentials
# 8. Rename this file to .env

# Instructions for China Cloud (21Vianet):
# 1. Go to https://portal.azure.cn
# 2. Navigate to Azure Active Directory → App registrations → New registration
# 3. Follow the same steps as above
# 4. Set MS365_MCP_CLOUD_TYPE=china

# -------------------------------------------------------------------
# Azure Key Vault Integration (Optional)
# -------------------------------------------------------------------
# When set, secrets are fetched from Azure Key Vault instead of environment variables.
# This is useful for production deployments, especially with Azure Container Apps.
#
# MS365_MCP_KEYVAULT_URL=https://your-keyvault-name.vault.azure.net
#
# Key Vault secret names (store these in your Key Vault):
#   - ms365-mcp-client-id     (required)
#   - ms365-mcp-tenant-id     (optional, defaults to "common")
#   - ms365-mcp-client-secret (optional)
#   - ms365-mcp-cloud-type    (optional, defaults to "global")
#
# Authentication uses DefaultAzureCredential, which supports:
#   - Managed Identity (recommended for Azure Container Apps)
#   - Azure CLI credentials (for local development)
#   - Environment variables (AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, AZURE_TENANT_ID)
#
# See README.md for detailed Azure Key Vault setup instructions.

# -------------------------------------------------------------------
# OpenTelemetry (optional — no-op when unset)
# -------------------------------------------------------------------
# Set to your OTel collector's OTLP/HTTP endpoint to export traces and metrics.
# When unset, the OTel SDK boots silently with no network traffic.
# Note: this env var is read at startup BEFORE dotenv/config loads — it must
# be set in the process environment (systemd unit, Docker env, CI secret),
# not in .env, to take effect.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Prometheus /metrics endpoint on port 9464 (set to 1 to enable)
# MS365_MCP_PROMETHEUS_ENABLED=

# -------------------------------------------------------------------
# Logger
# -------------------------------------------------------------------
# Log level: error | warn | info | debug (default: info in prod, debug in dev)
# LOG_LEVEL=info

# Optional directory for log files. When unset, only stdout/stderr is used.
# Must be writable by the server process. Use an absolute path.
# MS365_MCP_LOG_DIR=

# Set to 1 to include request bodies in debug-level logs (NEVER at info level).
# Only effective when LOG_LEVEL=debug. Never logs refresh tokens at any level.
# MS365_MCP_LOG_REQUEST_BODIES=

# -------------------------------------------------------------------
# HTTP transport — production security posture (plan 01-07 / D-02)
# -------------------------------------------------------------------
# When running in production HTTP mode (NODE_ENV=production + --http), the
# server REFUSES to start unless both MS365_MCP_PUBLIC_URL and
# MS365_MCP_CORS_ORIGINS are set (exit 78 / EX_CONFIG at startup).
# Dev mode (NODE_ENV != production) tolerates both being unset: any
# http(s)://localhost:* origin is auto-permitted, and OAuth metadata uses
# the request host.

# Public / externally-reachable origin used for browser-facing OAuth
# redirects when running behind a reverse proxy (Caddy, nginx, Traefik).
# Server-to-server endpoints stay on the request host so internal clients
# do not need NAT loopback through the proxy.
# MS365_MCP_PUBLIC_URL=https://mcp.example.com

# Comma-separated allowlist of origins permitted by CORS in production
# HTTP mode. Exact-string match, no wildcards. Required when NODE_ENV
# is production and --http is set.
# MS365_MCP_CORS_ORIGINS=https://app.example.com,https://desktop.example.com

# Deprecated (v1 compat): singular MS365_MCP_CORS_ORIGIN is honored with a
# warn log. Migrate to MS365_MCP_CORS_ORIGINS (plural). Removal target: v2.1.
# MS365_MCP_CORS_ORIGIN=

# Deprecated (v1 compat): MS365_MCP_BASE_URL is honored as a fallback for
# MS365_MCP_PUBLIC_URL. Migrate to MS365_MCP_PUBLIC_URL. Removal target: v2.1.
# MS365_MCP_BASE_URL=

# -------------------------------------------------------------------
# Upload session — Plan 02-06 / MWARE-05
# -------------------------------------------------------------------
# Default chunk size in bytes for graph-upload-large-file (320 KiB aligned;
# hard cap 60 MiB per chunk). Microsoft's documented sweet spot is 3.125 MB
# (320 KiB × 10 = 3,276,800 bytes). Non-aligned values are snapped DOWN to
# the nearest 320 KiB multiple; zero / unset falls back to the default.
# MS365_MCP_UPLOAD_CHUNK_SIZE_BYTES=3276800

# Express body-parser byte ceiling for json / urlencoded payloads in HTTP
# transport mode. Raised from express's 100 KB default to accommodate
# base64-encoded upload payloads (MWARE-05) through the MCP tool surface.
# Accepts any value express's body-parser understands (e.g., '500kb',
# '10mb', '1gb'). A request body larger than this returns HTTP 413 before
# reaching any tool handler.
# MS365_MCP_BODY_PARSER_LIMIT=60mb

# -------------------------------------------------------------------
# Phase 3 (plan 03-01..05) — Postgres / Redis / KEK substrates
# -------------------------------------------------------------------
# Each sibling plan edits ONLY between its own `region:phase3-<name>` and
# `endregion:phase3-<name>` markers. Marker comments are load-bearing —
# do not delete them. grep counts must remain exactly 2 per name.

# region:phase3-postgres
# Phase 3 (plan 03-01) — Postgres
# Connection string for the tenant registry DB. In Docker Compose this
# resolves to the `postgres` service; bare-metal deployments point at the
# local or remote Postgres instance. Password must come from a secret store
# in production — the example below is for local dev only.
MS365_MCP_DATABASE_URL=postgres://mcp:changeme@localhost:5432/mcp

# pg.Pool max connections (min is fixed at 2). Bump for multi-replica
# or high-burst deployments.
MS365_MCP_DB_POOL_MAX=20

# Auto-run `node bin/migrate.mjs up` at container startup. Set to 0 when
# you want exclusive control (e.g., multi-replica deploy where only one
# container should apply migrations — see RESEARCH.md Pitfall 7).
MS365_MCP_MIGRATE_ON_STARTUP=1
# endregion:phase3-postgres

# region:phase3-redis
# endregion:phase3-redis

# region:phase3-kek
# Phase 3 (plan 03-04) — Token encryption (D-12 / SECUR-01)
# Primary KEK source: base64-encoded 32-byte key wrapping per-tenant DEKs.
# Generate: openssl rand -base64 32
MS365_MCP_KEK=

# Optional: Azure Key Vault layering. When MS365_MCP_KEYVAULT_URL is set and
# MS365_MCP_KEK is empty, the KEK is fetched from the Key Vault secret named
# `mcp-kek`. Env MS365_MCP_KEK wins on collision (dev convenience).
# MS365_MCP_KEYVAULT_URL=https://<your-vault>.vault.azure.net/

# Optional: transitional env var for the quarterly KEK rotation window.
# Reserved for 03-05 dual-KEK acquire; not consumed in Phase 3 Plan 04.
# MS365_MCP_KEK_PREVIOUS=
# endregion:phase3-kek