# Primary reverse-proxy reference for ms-365-mcp-server v2 (OPS-10).
#
# Terminates TLS, preserves X-Forwarded-* (set MS365_MCP_TRUST_PROXY=1 so
# Express honors the real client IP + scheme), and disables buffering for SSE
# streams so long-lived MCP notifications pass through in real time.
#
# Replace mcp.example.com with your public hostname. The container is
# reachable at 127.0.0.1:3000 per examples/docker-compose/docker-compose.yml.
#
mcp.example.com {
  tls ops@example.com

  # Admin endpoints belong on admin.example.com with stricter ACL/SSO.
  handle /admin* {
    respond 404
  }

  # Tenant-scoped v2 MCP/OAuth/webhook routes.
  handle /t/* {
    reverse_proxy 127.0.0.1:3000 {
      header_up Host {host}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}

      flush_interval -1
      transport http {
        read_timeout 1h
        write_timeout 1h
      }
    }
  }

  # Legacy MCP endpoints (Streamable HTTP + legacy SSE shim).
  #
  # SSE (Server-Sent Events) is a long-lived streaming response; Caddy's
  # default buffering would hold events until a chunk boundary, breaking
  # the real-time notification contract. `flush_interval -1` disables
  # buffering entirely (matches nginx's `proxy_buffering off`).
  handle /mcp* {
    reverse_proxy 127.0.0.1:3000 {
      header_up Host {host}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}

      flush_interval -1
      transport http {
        read_timeout 1h
        write_timeout 1h
      }
    }
  }

  # OAuth 2.1 proxy endpoints (authorize / token / register / metadata).
  # No SSE concerns here; straight forwarding with preserved headers is
  # enough. These endpoints MUST receive X-Forwarded-Proto=https so the
  # OAuth metadata generation emits https:// issuer/authorization URLs
  # rather than mirroring the container's http:// upstream.
  handle /authorize /token /register /.well-known/* {
    reverse_proxy 127.0.0.1:3000 {
      header_up Host {host}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
    }
  }

  # Health probes — no auth, no origin validation, no buffering concerns.
  # Caddy's default access logging for /healthz and /readyz can generate
  # 2880+ log lines/day per probe source; silence them here.
  handle /healthz /readyz {
    reverse_proxy 127.0.0.1:3000
    log_skip
  }

  # Metrics are private by default. Publish them on a separate hostname with
  # auth/IP allowlist after setting MS365_MCP_METRICS_BEARER.
  handle /metrics {
    respond 404
  }

  # Log format: JSON for aggregation compatibility (Loki / Grafana / ES).
  log {
    output stdout
    format json
  }
}
