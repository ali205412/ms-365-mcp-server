# Example .env for examples/docker-compose/docker-compose.yml.
#
# Copy to `.env` (same directory as docker-compose.yml), fill in the real
# values, and: `docker compose up -d`. Secrets committed here would leak;
# .env is gitignored in this repo.

# =========================================================================
# REQUIRED
# =========================================================================

# Public URL the MCP server will advertise (OAuth redirect base). Must be
# set in production HTTP mode — the server exits 78 at startup without it.
# If you front the service with a TLS-terminating reverse proxy, set this
# to the proxy's public URL, not the container's.
MS365_MCP_PUBLIC_URL=https://mcp.example.com

# Comma-separated list of CORS origins allowed to hit /mcp. Required in
# production HTTP mode for browser-resident MCP clients.
MS365_MCP_CORS_ORIGINS=https://mcp.example.com,https://claude.ai

# 32-byte base64-encoded key. Wraps every per-tenant DEK. Generate with:
#   openssl rand -base64 32
# NEVER commit to source control. Rotate with `node dist/bin/rotate-kek.mjs`;
# MS365_MCP_KEK_PREVIOUS holds the prior value during rotation.
MS365_MCP_KEK=
# MS365_MCP_KEK_PREVIOUS=

# =========================================================================
# POSTGRES + REDIS (in-compose defaults work; override for managed backends)
# =========================================================================

# If you use an external Postgres (RDS, managed PG), set MS365_MCP_DATABASE_URL
# here and either stop the postgres: service or ignore it. The compose file's
# default `postgresql://mcp:mcp@postgres:5432/mcp` matches the in-compose
# postgres service.
# MS365_MCP_DATABASE_URL=

# Credentials for the in-compose Postgres (initdb-time). Ignored when
# MS365_MCP_DATABASE_URL points elsewhere.
POSTGRES_USER=mcp
POSTGRES_PASSWORD=mcp
POSTGRES_DB=mcp

# If you use external Redis (ElastiCache, Upstash), set MS365_MCP_REDIS_URL
# here. The compose default `redis://redis:6379` matches the in-compose redis
# service. Add a password by baking it into the URL and setting REDIS_PASSWORD.
# MS365_MCP_REDIS_URL=redis://:strongpw@redis:6379
# REDIS_PASSWORD=strongpw

# =========================================================================
# OPTIONAL — admin dual-stack auth (plan 04-04)
# =========================================================================

# When both are set, /admin/* requires Entra OAuth + group membership (in
# addition to API keys). Unset = API-key-only admin.
# MS365_MCP_ADMIN_APP_CLIENT_ID=00000000-0000-0000-0000-000000000000
# MS365_MCP_ADMIN_GROUP_ID=00000000-0000-0000-0000-000000000000
# MS365_MCP_ADMIN_ORIGINS=https://admin.example.com

# =========================================================================
# OPTIONAL — observability
# =========================================================================

# OTLP endpoint for traces + metrics (leave unset for silent bootstrap).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Prometheus /metrics exposition (scrape target :9464). Unset to disable.
# MS365_MCP_PROMETHEUS_ENABLED=1

# =========================================================================
# OPTIONAL — shutdown tuning
# =========================================================================

# Graceful drain budget. Must be STRICTLY LESS than stop_grace_period in
# docker-compose.yml (default 30s) so the in-process failsafe fires before
# Docker sends SIGKILL.
# MS365_MCP_SHUTDOWN_GRACE_MS=25000
